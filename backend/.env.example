# Local testing (OTP shown in API + UI)
AUTH_OTP_MODE=demo
ALLOW_DEBUG_OTP=true
AUTH_SECRET=change-me-before-production

# Production (real SMS, no OTP in response)
# AUTH_OTP_MODE=sms
# ALLOW_DEBUG_OTP=false
# AUTH_SECRET=<strong-random-secret>

# Email (newsletter + Notify Me confirmations) — copy to backend/.env
# Gmail: App Password required — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Swastik Makhana
SMTP_USE_TLS=true

# Optional AI chat (uses OpenAI; works without this via built-in product knowledge)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
