# Optional — only if you deploy the FastAPI backend separately
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phone login (OTP) — works on Vercel without a separate backend
AUTH_SECRET=change-me-to-a-long-random-string
# Show OTP on screen for testing (set true on Vercel until SMS is wired)
ALLOW_DEBUG_OTP=true
# AUTH_OTP_TTL_SECONDS=300
# AUTH_SESSION_TTL_SECONDS=2592000

# Notify Me + newsletter emails — FROM your Gmail, TO customer's email
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sanjayndls09@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=sanjayndls09@gmail.com
SMTP_FROM_NAME=Swastik Makhana
SMTP_USE_TLS=true
